# Copy to .env.local for local dev (never commit .env.local)

# Supabase — Project Settings → API
# Use the base Project URL only — NOT the /rest/v1/ endpoint
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# AI assistant — server-side only (NEVER use NEXT_PUBLIC_ or VITE_ for API keys)
# xAI Grok is preferred when set; falls back to OpenAI
# XAI_API_KEY=your_xai_api_key_here
# OPENAI_API_KEY=sk-...